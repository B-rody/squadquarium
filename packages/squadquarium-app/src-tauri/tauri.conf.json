{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "squadquarium",
  "version": "0.1.0",
  "identifier": "xyz.squadquarium.app",
  "build": {
    "devUrl": "http://127.0.0.1:6280",
    "frontendDist": "http://127.0.0.1:6280"
  },
  "app": {
    "windows": [
      {
        "title": "squadquarium",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "focus": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "squadquarium"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../cli/dist": "resources/cli-dist"
    }
  }
}
